      "id": "enable",
      "type": "promptString",
      "description": "Enable (true/false)",
      "default": "true"
    },
    {
      "id": "fwuImage",
      "type": "promptString",
      "description": "Path to .bin to flash onto the powerbank",
      "default": "${workspaceFolder}/../../firmware/P1TT2C-firmware/build/P1TT2C-firmware.bin"
    },
    {
      "id": "stationFwuImage",
      "type": "promptString",
      "description": "Path to .bin to flash onto the station (typically build/zephyr/zephyr.bin)",
      "default": "${workspaceFolder}/../../firmware/S1TTXX-firmware/build/zephyr/zephyr.bin"
    },
    {
      "id": "hexFrame",
      "type": "promptString",
      "description": "Hex frame to convert (e.g., 'ea 01 05 c0 23' or 'ea0105c023')",
      "default": "ea 01 05 c0 23"
    }
